{
  "_comment": "Merged into ~/.gemini/settings.json by `stash signin` (or by hand for <project>/.gemini/settings.json). Commands are machine-independent — `stash hook run gemini <event>` executes the scripts shipped inside the stashai package. Timeouts are in MILLISECONDS.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-session-start",
            "command": "stash hook run gemini on_session_start",
            "timeout": 5000,
            "description": "Record Stash session id"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-prompt",
            "command": "stash hook run gemini on_prompt",
            "timeout": 3000,
            "description": "Stream user prompt to Stash"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-tool-use",
            "command": "stash hook run gemini on_tool_use",
            "timeout": 5000,
            "description": "Stream tool use to Stash history"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-stop",
            "command": "stash hook run gemini on_stop",
            "timeout": 10000,
            "description": "Stream session end to Stash"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-session-end",
            "command": "stash hook run gemini on_session_end",
            "timeout": 5000,
            "description": "Clear Stash session state"
          }
        ]
      }
    ]
  }
}
