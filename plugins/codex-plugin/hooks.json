{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "stash hook run codex on_session_start", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "stash hook run codex on_prompt", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          { "type": "command", "command": "stash hook run codex on_tool_use", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "stash hook run codex on_stop", "timeout": 10 }
        ]
      }
    ]
  }
}
