{
  "_comment": "Copy to ~/.codex/hooks.json. Requires `features.codex_hooks = true` in ~/.codex/config.toml. Timeouts are in SECONDS. `matcher` is a regex string. Tool hooks are Bash-only today; non-Bash tools fall back to the `notify` command in config.toml (see README).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_session_start", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_prompt", "timeout": 3 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          { "type": "command", "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_tool_use", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_stop", "timeout": 10 }
        ]
      }
    ]
  }
}
