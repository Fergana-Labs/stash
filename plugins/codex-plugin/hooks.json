{
  "_comment": "Copy to ~/.codex/hooks.json. Requires `features.codex_hooks = true` in ~/.codex/config.toml. Tool hooks are Bash-only today; non-Bash tools fall back to the `notify` command in config.toml (see README).",
  "hooks": {
    "SessionStart": [
      { "command": ["python3", "${PLUGIN_ROOT}/scripts/on_session_start.py"], "timeout_ms": 5000 }
    ],
    "UserPromptSubmit": [
      { "command": ["python3", "${PLUGIN_ROOT}/scripts/on_prompt.py"], "timeout_ms": 3000 }
    ],
    "PostToolUse": [
      {
        "matcher": { "tool": "Bash" },
        "command": ["python3", "${PLUGIN_ROOT}/scripts/on_tool_use.py"],
        "timeout_ms": 2000
      }
    ],
    "Stop": [
      { "command": ["python3", "${PLUGIN_ROOT}/scripts/on_stop.py"], "timeout_ms": 10000 }
    ]
  }
}
