{
  "id": "octopus",
  "name": "Octopus",
  "version": "0.1.0",
  "description": "Octopus memory backend — server-side scored injection, activity streaming, cross-session context",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiEndpoint": {
        "type": "string",
        "default": "https://getboozle.com",
        "description": "Octopus API base URL"
      },
      "apiKey": {
        "type": "string",
        "description": "Agent API key (from Octopus registration)"
      },
      "agentName": {
        "type": "string",
        "description": "Agent identity name in Octopus"
      },
      "workspaceId": {
        "type": "string",
        "description": "Default workspace UUID"
      },
      "historyStoreId": {
        "type": "string",
        "description": "History store UUID for activity streaming"
      }
    },
    "required": ["apiKey", "agentName"],
    "additionalProperties": false
  },
  "uiHints": {
    "apiKey": { "secret": true }
  }
}
