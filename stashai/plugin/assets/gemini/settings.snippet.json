{
  "_comment": "Merged into ~/.gemini/settings.json by `stash signin` (or by hand for <project>/.gemini/settings.json). ${PLUGIN_ROOT} is the absolute path to this plugin dir. Timeouts are in MILLISECONDS.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-session-start",
            "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_session_start",
            "timeout": 5000,
            "description": "Record Stash session id"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-prompt",
            "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_prompt",
            "timeout": 3000,
            "description": "Stream user prompt to Stash"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-tool-use",
            "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_tool_use",
            "timeout": 5000,
            "description": "Stream tool use to Stash history"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-stop",
            "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_stop",
            "timeout": 10000,
            "description": "Stream session end to Stash"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-session-end",
            "command": "bash ${PLUGIN_ROOT}/scripts/_run.sh on_session_end",
            "timeout": 5000,
            "description": "Clear Stash session state"
          }
        ]
      }
    ]
  }
}
