# ─────────────────────────────────────────────
# Octopus — environment variable reference
# Copy to .env and fill in values for your environment.
# Variables marked [required] must be set for that feature to work.
# ─────────────────────────────────────────────

# ── Server ───────────────────────────────────
PORT=3456

# ── Database ─────────────────────────────────
# Used by docker-compose.prod.yml. Choose strong credentials.
POSTGRES_USER=octopus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=octopus

# Full connection string used by the backend directly.
DATABASE_URL=postgresql://octopus:changeme@postgres:5432/octopus

# Connection pool sizing. Increase DB_POOL_MAX for high-traffic deployments.
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── URLs & CORS ───────────────────────────────
# PUBLIC_URL is the frontend origin (used for invite links, CORS defaults).
# ⚠ PRODUCTION: set to your actual domain, e.g. https://app.yourcompany.com
PUBLIC_URL=http://localhost:3457
CORS_ORIGINS=http://localhost:3457,http://localhost:3456

# ── LLM — Anthropic [required for sleep agent + universal search] ──
ANTHROPIC_API_KEY=

# ── LLM — OpenAI / Embeddings [required for semantic search] ─────────
OPENAI_API_KEY=sk-proj-...your-key-here...

# EMBEDDING_API_KEY=sk-...   # optional override for embedding-only key

# ── Sleep Agent ───────────────────────────────
# Set to "true" to enable the background curation agent.
SLEEP_AGENT_ENABLED=true
# How often (seconds) the scheduler checks for agents due to run.
SLEEP_AGENT_CHECK_INTERVAL=300

# ── File Storage (S3-compatible) ─────────────
# Octopus supports any S3-compatible object store (AWS S3, Cloudflare R2, MinIO).
# Leave blank to disable file uploads.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=octopus
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_REGION=auto

# ── RAGFlow (optional PDF parsing) ───────────
# Connect to a self-hosted RAGFlow instance for structured document ingestion.
# Leave blank to disable.
# RAGFLOW_API_URL=http://localhost:9380
# RAGFLOW_API_KEY=...

# ── Auth0 (optional — human account SSO) ─────
# Create a Regular Web Application in Auth0, then create an API with an
# identifier (audience). Persona/agent accounts continue to use mc_ API keys.
# Leave blank to disable Auth0 (password-only login remains available).
# AUTH0_DOMAIN=dev-abc123.us.auth0.com
# AUTH0_AUDIENCE=https://getoctopus.com/api

# ── BFF session secret (frontend) ────────────
# Also set SESSION_SECRET in frontend/.env.local (min 32 chars).
# Generate with: openssl rand -hex 32
# SESSION_SECRET=replace_with_at_least_32_chars_random_string
