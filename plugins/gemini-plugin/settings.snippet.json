{
  "_comment": "Merge the `hooks` block below into ~/.gemini/settings.json or <project>/.gemini/settings.json. Replace ${PLUGIN_ROOT} with the absolute path to this plugin dir. Timeouts are in MILLISECONDS.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "octopus-session-start",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_session_start.py",
            "timeout": 5000,
            "description": "Warm Octopus context cache"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "octopus-prompt",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_prompt.py",
            "timeout": 3000,
            "description": "Stream user prompt to Octopus"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "name": "octopus-tool-use",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_tool_use.py",
            "timeout": 2000,
            "description": "Stream tool use to Octopus history"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "octopus-stop",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_stop.py",
            "timeout": 10000,
            "description": "Stream session summary to Octopus"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "octopus-session-end",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_session_end.py",
            "timeout": 5000,
            "description": "Clear Octopus session state"
          }
        ]
      }
    ]
  }
}
